CREATE TABLE upi_users (id BIGSERIAL PRIMARY KEY, upi_id TEXT UNIQUE NOT NULL, masked_upi TEXT, refer_code TEXT UNIQUE, referred_by TEXT, total_earnings NUMERIC DEFAULT 0, created_at TIMESTAMP DEFAULT NOW()); CREATE TABLE upi_conversions (id BIGSERIAL PRIMARY KEY, upi_id TEXT NOT NULL, offer_name TEXT, event TEXT, amount NUMERIC DEFAULT 0, status TEXT DEFAULT 'pending', refer_upi TEXT, refer_amount NUMERIC DEFAULT 0, created_at TIMESTAMP DEFAULT NOW()); CREATE TABLE upi_payouts (id BIGSERIAL PRIMARY KEY, upi_id TEXT NOT NULL, amount NUMERIC, status TEXT DEFAULT 'pending', created_at TIMESTAMP DEFAULT NOW()); CREATE TABLE referrals (id BIGSERIAL PRIMARY KEY, code TEXT UNIQUE NOT NULL, offer_id TEXT, offer_name TEXT, referrer_upi TEXT, user_payout NUMERIC DEFAULT 0, my_payout NUMERIC DEFAULT 0, created_at TIMESTAMP DEFAULT NOW()); CREATE TABLE clicks (id BIGSERIAL PRIMARY KEY, click_id TEXT, offer_name TEXT, referred_by TEXT, user_payout NUMERIC, my_payout NUMERIC, created_at TIMESTAMP DEFAULT NOW()); CREATE TABLE offer_status (id BIGSERIAL PRIMARY KEY, offer_name TEXT UNIQUE, is_active BOOLEAN DEFAULT true, created_at TIMESTAMP DEFAULT NOW());
